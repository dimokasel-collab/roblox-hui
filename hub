local function createSlider(titleText, posY, minV, maxV, startV, isVar)
	local sL = Instance.new("TextLabel", frame) sL.Size, sL.Position, sL.Text, sL.TextColor3, sL.Font, sL.TextSize, sL.BackgroundTransparency = UDim2.new(0.9, 0, 0, 14), UDim2.new(0.05, 0, 0, posY), titleText .. ": " .. startV, Color3.fromRGB(0, 0, 0), Enum.Font.SourceSansBold, 11, 1
	sL.TextScaled = false local sF = Instance.new("Frame", frame) sF.Size, sF.Position, sF.BackgroundColor3 = UDim2.new(0.9, 0, 0, 4), UDim2.new(0.05, 0, 0, posY + 14), Color3.fromRGB(220, 225, 230)
	local sFill = Instance.new("Frame", sF) sFill.Size, sFill.BackgroundColor3 = UDim2.new(0.3, 0, 1, 0), Color3.fromRGB(0, 195, 255)
	local sB = Instance.new("TextButton", sF) sB.Size, sB.Position, sB.BackgroundColor3, sB.Text = UDim2.new(0, 10, 0, 10), UDim2.new(0.3, -5, -0.7, 0), Color3.fromRGB(0, 195, 255), ""
	Instance.new("UICorner", sB).CornerRadius = UDim.new(1, 0) Instance.new("UIStroke", sB).Color = Color3.fromRGB(0, 0, 0)
	local startP = (startV - minV) / (maxV - minV) sB.Position, sFill.Size = UDim2.new(startP, -5, -0.7, 0), UDim2.new(startP, 0, 1, 0)
	local drag = false local function update()
		local p = math.clamp((U:GetMouseLocation().X - sF.AbsolutePosition.X) / sF.AbsoluteSize.X, 0, 1) sB.Position, sFill.Size = UDim2.new(p, -5, -0.7, 0), UDim2.new(p, 0, 1, 0)
		local val = math.round(minV + (p * (maxV - minV))) if isVar == 1 then _G.walkSpeed = val elseif isVar == 2 then _G.flySpeed = val else _G.flingRadius = val end sL.Text = titleText .. ": " .. val
	end
	sB.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end end) U.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end) R.Heartbeat:Connect(function() if drag then update() end end)
end
