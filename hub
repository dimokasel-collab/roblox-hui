function refreshPlayerList(scrollingFrame)
	for _, v in ipairs(scrollingFrame:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
	local count = 0
	
	for _, p in ipairs(P:GetPlayers()) do
		if p and p ~= pl and p.Parent == P and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local targetRoot = p.Character.HumanoidRootPart
			local targetHum = p.Character:FindFirstChildOfClass("Humanoid")
			
			if targetHum and targetHum.Health > 0 and targetRoot:IsA("BasePart") then
				local pFrame = Instance.new("Frame", scrollingFrame)
				pFrame.Size, pFrame.Position = UDim2.new(0.95, 0, 0, 24), UDim2.new(0.025, 0, 0, count * 28)
				pFrame.BackgroundColor3, pFrame.BackgroundTransparency = Color3.fromRGB(0, 195, 255), 0.3
				Instance.new("UICorner", pFrame).CornerRadius = UDim.new(0, 4)
				local ps = Instance.new("UIStroke", pFrame) ps.Color = Color3.fromRGB(255, 255, 255)
				
				local pName = Instance.new("TextLabel", pFrame)
				pName.Size, pName.Position, pName.Text, pName.TextColor3 = UDim2.new(0.7, 0, 1, 0), UDim2.new(0.05, 0, 0, 0), p.Name, Color3.fromRGB(0, 0, 0)
				pName.Font, pName.TextSize, pName.TextXAlignment, pName.BackgroundTransparency = Enum.Font.SourceSansBold, 11, Enum.TextXAlignment.Left, 1
				
				local tpBtn = Instance.new("TextButton", pFrame)
				tpBtn.Size, tpBtn.Position, tpBtn.BackgroundColor3, tpBtn.Text, tpBtn.TextColor3, tpBtn.Font, tpBtn.TextSize = UDim2.new(0.2, 0, 0.8, 0), UDim2.new(0.75, 0, 0.1, 0), Color3.fromRGB(215, 45, 75), "TP", Color3.new(1,1,1), Enum.Font.SourceSansBold, 11
				Instance.new("UICorner", tpBtn).CornerRadius = UDim.new(0, 4)
				
				tpBtn.MouseButton1Click:Connect(function()
					local myRoot = pl.Character and pl.Character:FindFirstChild("HumanoidRootPart")
