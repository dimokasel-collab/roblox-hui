-- ИСПРАВЛЕНО: Жёсткое наведение флинга без потери и накладок службы игроков [IY]
function toggleWalkFling()
	_G.walkfling = not _G.walkfling
	if not _G.walkfling then if wfConn then wfConn:Disconnect() end if _G.updateVisuals then _G.updateVisuals() end return end
	wfConn = R.Heartbeat:Connect(function()
		local myChar = pl.Character
		local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
		local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
		if not myRoot or not myHum or myHum.Health <= 0 then return end
		pcall(function()
			local target, minDist = nil, 8
			for _, p in ipairs(P:GetPlayers()) do
				if p ~= pl and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
					local dist = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude
					if dist < minDist then minDist = dist target = p.Character.HumanoidRootPart end
				end
			end
			if target then
				local curCF = myRoot.CFrame
				myRoot.AssemblyLinearVelocity = myRoot.CFrame.LookVector * 10000 + Vector3.new(0, 10000, 0)
				myRoot.CFrame = target.CFrame * CFrame.new(0, 0, math.sin(tick() * 60) * 1.5)
				R.Heartbeat:Wait()
				myRoot.CFrame = curCF
				myRoot.Anchored = true
				myRoot.AssemblyLinearVelocity, myRoot.AssemblyAngularVelocity, myRoot.Velocity, myRoot.RotVelocity = Vector3.zero, Vector3.zero, Vector3.zero, Vector3.zero
				R.Heartbeat:Wait()
				myRoot.Anchored = false
			else
				if not _G.fly then myRoot.Velocity = Vector3.new(myRoot.Velocity.X, 0, myRoot.Velocity.Z) end
			end
		end)
	end)
	if _G.updateVisuals then _G.updateVisuals() end
end
