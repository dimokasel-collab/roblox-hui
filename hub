local isHovered = false
local currentSpeed, maxSpeed, acceleration = 0, 272, 204
local spinConn

local function startSpinning()
	if spinConn then spinConn:Disconnect() end
	spinConn = R.Heartbeat:Connect(function(dt)
		if isHovered then
			currentSpeed = math.min(maxSpeed, currentSpeed + acceleration * dt)
			rotator.Rotation = (rotator.Rotation + currentSpeed * dt) % 360
		else
			currentSpeed = math.max(0, currentSpeed - acceleration * 2 * dt)
			if currentSpeed > 0 then
				rotator.Rotation = (rotator.Rotation + currentSpeed * dt) % 360
			else
				local curRot = rotator.Rotation
				if math.abs(curRot) > 1 then rotator.Rotation = curRot - (curRot * 15 * dt) else rotator.Rotation = 0 if spinConn then spinConn:Disconnect() spinConn = nil end end
			end
		end
	end)
end

